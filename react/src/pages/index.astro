---
import Layout from '../layouts/Layout.astro';

// Import React components and mark them as islands for client-side interactivity.
// Using 'client:load' for TzikTzakSection to ensure it hydrates early.

import Navbar from '../components/Navbar.tsx?component-island';
import Hero from '../components/Hero.tsx?component-island';
import PASSection from '../components/PASSection.tsx?component-island';
import TzikTzakSection from '../components/TzikTzakSection.tsx?component-island';
import ComparisonSection from '../components/ComparisonSection.tsx?component-island';
import ValueProps from '../components/ValueProps.tsx?component-island';
import ProcessSection from '../components/ProcessSection.tsx?component-island';
import ExpertSection from '../components/ExpertSection.tsx?component-island';
import TestimonialsSection from '../components/TestimonialsSection.tsx?component-island';
import FAQSection from '../components/FAQSection.tsx?component-island';
import CloserSection from '../components/CloserSection.tsx?component-island';
import Footer from '../components/Footer.tsx?component-island';

---

<Layout>
  <main class="min-h-screen font-sans text-brand-dark bg-brand-cream selection:bg-brand-gold selection:text-white">
    <Navbar client:visible />
    <Hero client:visible />
    <PASSection client:visible />
    <TzikTzakSection client:load /> {/* Changed to client:load */}
    <ComparisonSection client:visible />
    <ValueProps client:visible />
    <ProcessSection client:visible />
    <ExpertSection client:visible />
    <TestimonialsSection client:visible />
    <FAQSection client:visible />
    <CloserSection client:visible />
    <Footer client:visible />
  </main>
</Layout>
